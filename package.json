{
  "name": "cowboy-cli",
  "version": "0.1.0",
  "description": "Install and manage AI agent skills and MCPs across coding agents",
  "type": "module",
  "bin": {
    "cowboy": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc && cp -r src/skills dist/skills",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "ai",
    "agents",
    "skills",
    "mcp",
    "claude",
    "codex"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.3.2",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "gray-matter": "^4.0.3",
    "simple-git": "^3.33.0",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
