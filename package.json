{
  "name": "cowboy-cli",
  "version": "0.1.0",
  "description": "The package manager for AI agent skills",
  "type": "module",
  "bin": {
    "cowboy": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc && cp -r src/skills dist/skills",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run test && npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oneprompteu/cowboy.git"
  },
  "homepage": "https://github.com/oneprompteu/cowboy#readme",
  "bugs": {
    "url": "https://github.com/oneprompteu/cowboy/issues"
  },
  "keywords": [
    "ai",
    "agents",
    "skills",
    "mcp",
    "claude",
    "codex"
  ],
  "license": "MIT",
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20.12.0"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.3.2",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "gray-matter": "^4.0.3",
    "simple-git": "^3.33.0",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
